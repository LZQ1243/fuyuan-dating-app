<!-- 手机号登录页 -->
<view class="container">
  <!-- 顶部装饰 -->
  <view class="header-decoration">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <view class="title">手机号登录</view>
    <view class="subtitle">未注册的手机号将自动注册</view>

    <!-- 表单 -->
    <view class="form">
      <view class="form-item">
        <image class="icon" src="/images/icons/phone.png"></image>
        <input 
          class="input" 
          type="number" 
          placeholder="请输入手机号" 
          maxlength="11"
          value="{{phone}}"
          bindinput="handlePhoneInput"
        />
      </view>

      <view class="form-item">
        <image class="icon" src="/images/icons/code.png"></image>
        <input 
          class="input" 
          type="number" 
          placeholder="请输入验证码" 
          maxlength="6"
          value="{{code}}"
          bindinput="handleCodeInput"
        />
        <button 
          class="code-btn {{canSend ? '' : 'disabled'}}" 
          bindtap="sendCode"
          disabled="{{!canSend}}"
        >
          {{codeText}}
        </button>
      </view>
    </view>

    <!-- 登录按钮 -->
    <button class="btn-login" bindtap="handleLogin">登录</button>

    <!-- 底部链接 -->
    <view class="footer">
      <text class="link" bindtap="goToRegister">注册账号</text>
      <text class="separator">|</text>
      <text class="link" bindtap="goBack">返回首页</text>
    </view>
  </view>
</view>
