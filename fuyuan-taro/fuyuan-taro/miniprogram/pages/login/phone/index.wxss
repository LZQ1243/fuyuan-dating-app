/* 手机号登录页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ff6b9d 0%, #ff8fab 100%);
  position: relative;
  overflow: hidden;
}

.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  top: -100rpx;
  right: -50rpx;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  top: 50rpx;
  right: 100rpx;
}

.circle-3 {
  width: 150rpx;
  height: 150rpx;
  top: 150rpx;
  right: 50rpx;
}

.content {
  position: relative;
  padding: 200rpx 60rpx 60rpx;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 60rpx;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 48rpx;
  padding: 10rpx 30rpx;
}

.icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 32rpx;
  color: #333333;
}

.code-btn {
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  background-color: #ff6b9d;
  color: #ffffff;
  font-size: 26rpx;
  border: none;
  border-radius: 30rpx;
  padding: 0;
  margin: 0;
}

.code-btn.disabled {
  background-color: #cccccc;
}

.btn-login {
  margin-top: 60rpx;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #ffffff;
  color: #ff6b9d;
  font-size: 36rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.footer {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 60rpx;
  gap: 20rpx;
}

.link {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.separator {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}
