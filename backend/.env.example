# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB配置（原有）
MONGODB_URI=mongodb://localhost:27017/fuyuan

# MySQL配置（新增）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=fuyuan

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# 消息队列配置
RABBITMQ_URL=amqp://localhost:5672

# 云存储配置（新增）
OSS_ACCESS_KEY=your_access_key
OSS_SECRET_KEY=your_secret_key
OSS_BUCKET=your_bucket_name
OSS_REGION=ap-guangzhou

# AI服务配置（新增）
ALIYUN_ASR_APPKEY=your_appkey
ALIYUN_ASR_TOKEN=your_token
TENCENT_FACE_API_KEY=your_api_key

# 敏感词过滤
ENABLE_SENSITIVE_WORD_FILTER=true
SENSITIVE_WORDS_PATH=./config/sensitive-words.txt

# 匹配算法配置
MATCH_RECOMMEND_LIMIT=20
MATCH_LEVEL_WEIGHT=40
MATCH_TYPE_WEIGHT=35
MATCH_LOCATION_WEIGHT=15
MATCH_AGE_WEIGHT=10

# 无障碍配置
ACCESSIBILITY_FONT_SIZE=16
ACCESSIBILITY_HIGH_CONTRAST=false

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
