# ====================================
# 通用数据库配置
# 支持所有厂商和所有类型的数据库
# ====================================

# 主数据库连接（必填）
# 支持的数据库类型：mongodb, mysql, mariadb, postgresql, sqlite, sqlserver, oracle, couchbase
# 格式：[type]://[username]:[password]@[host]:[port]/[database]?[options]

# 示例1: MongoDB（本地）
DATABASE_URI=mongodb://localhost:27017/fuyuan

# 示例2: MongoDB（阿里云）
# DATABASE_URI=mongodb://username:password@dds-bp123456.mongodb.rds.aliyuncs.com:3717/fuyuan?authSource=admin

# 示例3: MongoDB（腾讯云）
# DATABASE_URI=mongodb://username:password@mongo-123456.gz.mongodb.tencentcloudapi.com:27017/fuyuan

# 示例4: MongoDB（AWS DocumentDB）
# DATABASE_URI=mongodb://username:password@docdb-123456.us-east-1.docdb.amazonaws.com:27017/fuyuan?ssl=true&replicaSet=rs0&readPreference=secondaryPreferred

# 示例5: MongoDB（MongoDB Atlas）
# DATABASE_URI=mongodb+srv://username:password@cluster0.abcde.mongodb.net/fuyuan?retryWrites=true&w=majority

# 示例6: MySQL（本地）
# DATABASE_URI=mysql://root:password@localhost:3306/fuyuan

# 示例7: MySQL（阿里云RDS）
# DATABASE_URI=mysql://username:password@rm-bp123456.mysql.rds.aliyuncs.com:3306/fuyuan

# 示例8: MySQL（腾讯云CDB）
# DATABASE_URI=mysql://username:password@cdb-123456.gz.tencentcdb.com:3306/fuyuan

# 示例9: MySQL（AWS RDS）
# DATABASE_URI=mysql://username:password@db-instance.123456.us-east-1.rds.amazonaws.com:3306/fuyuan

# 示例10: MySQL（Google Cloud SQL）
# DATABASE_URI=mysql://username:password@10.0.0.1:3306/fuyuan

# 示例11: PostgreSQL（本地）
# DATABASE_URI=postgresql://postgres:password@localhost:5432/fuyuan

# 示例12: PostgreSQL（阿里云RDS）
# DATABASE_URI=postgresql://username:password@pgm-bp123456.pg.rds.aliyuncs.com:1921/fuyuan

# 示例13: PostgreSQL（AWS RDS）
# DATABASE_URI=postgresql://username:password@db-instance.123456.us-east-1.rds.amazonaws.com:5432/fuyuan

# 示例14: PostgreSQL（Azure Database）
# DATABASE_URI=postgresql://username:password@postgres-server.postgres.database.azure.com:5432/fuyuan

# 示例15: MariaDB（本地）
# DATABASE_URI=mariadb://root:password@localhost:3306/fuyuan

# 示例16: MariaDB（阿里云）
# DATABASE_URI=mariadb://username:password@rm-bp123456.mariadb.rds.aliyuncs.com:3306/fuyuan

# 示例17: SQLite（本地文件）
# DATABASE_URI=sqlite:./data/fuyuan.sqlite

# 示例18: SQL Server（本地）
# DATABASE_URI=sqlserver://sa:password@localhost:1433/fuyuan

# 示例19: SQL Server（Azure SQL）
# DATABASE_URI=sqlserver://username:password@server-name.database.windows.net:1433/fuyuan

# 示例20: Oracle（本地）
# DATABASE_URI=oracle://username:password@localhost:1521/orcl

# 示例21: Couchbase（本地）
# DATABASE_URI=couchbase://username:password@localhost:8091/fuyuan

# ====================================
# 辅助数据库配置（可选）
# ====================================

# 辅助数据库1 - 例如用于用户数据
# DATABASE_AUX1_URI=mysql://root:password@localhost:3306/users

# 辅助数据库2 - 例如用于日志数据
# DATABASE_AUX2_URI=postgresql://postgres:password@localhost:5432/logs

# ====================================
# 连接池配置
# ====================================

# 连接池大小
DB_POOL_SIZE=10
DB_MIN_POOL_SIZE=2

# 超时配置（毫秒）
DB_TIMEOUT=5000
DB_SOCKET_TIMEOUT=45000
DB_IDLE_TIMEOUT=30000

# ====================================
# 其他配置
# ====================================

NODE_ENV=development
PORT=3000

# Redis配置（如果使用）
REDIS_URI=redis://localhost:6379
# REDIS_URI=redis://:password@localhost:6379
# REDIS_URI=redis://username:password@redis-123456.cloud.redislabs.com:12345

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# 其他配置保持不变...
