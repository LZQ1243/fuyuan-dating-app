# ====================================
# 统一配置管理中心
# 所有服务对接和配置的统一入口
# ====================================

# ====================================
# 环境配置
# ====================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ====================================
# 数据库配置（通用）
# ====================================

# 主数据库（必填）
# 支持所有类型：mongodb, mysql, postgresql, sqlite, sqlserver, oracle, couchbase
DATABASE_URI=mongodb://admin:password@localhost:27017/fuyuan?authSource=admin

# 辅助数据库1（可选，例如用户数据）
# DATABASE_AUX1_URI=mysql://root:password@localhost:3306/fuyuan_users

# 辅助数据库2（可选，例如日志数据）
# DATABASE_AUX2_URI=postgresql://postgres:password@localhost:5432/fuyuan_logs

# 连接池配置
DB_POOL_SIZE=20
DB_MIN_POOL_SIZE=5
DB_TIMEOUT=5000
DB_SOCKET_TIMEOUT=60000
DB_IDLE_TIMEOUT=30000

# ====================================
# Redis配置
# ====================================
REDIS_URI=redis://localhost:6379
# REDIS_URI=redis://:password@localhost:6379

# 云Redis示例
# 阿里云: redis://:password@r-bp123456.redis.rds.aliyuncs.com:6379
# 腾讯云: redis://:password@redis-123456.redis.tencentcloudapi.com:6379
# AWS: redis://:password@cluster-name.abc123.use1.cache.amazonaws.com:6379

# ====================================
# RabbitMQ配置（可选）
# ====================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# 云RabbitMQ示例
# 阿里云: amqp://user:pass@mq-bp123456.mq.amqp.aliyuncs.com:5672
# AWS: amqps://user:pass@mq-instance.us-east-1.amazonaws.com:5672

# ====================================
# 存储配置
# ====================================

# 本地存储
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm
MAX_FILES_PER_UPLOAD=10

# 云存储配置（可选）
STORAGE_PROVIDER=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=ap-guangzhou
CDN_DOMAIN=

# ====================================
# AI服务配置（可选）
# ====================================

# 阿里云语音识别
ALIYUN_ASR_APPKEY=
ALIYUN_ASR_TOKEN=

# 腾讯人脸识别
TENCENT_FACE_API_KEY=
TENCENT_FACE_SECRET_ID=

# ====================================
# 认证配置
# ====================================

# JWT配置（必填，生产环境必须修改）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-change-this

# ====================================
# 上传配置
# ====================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm
MAX_FILES_PER_UPLOAD=10

# ====================================
# 安全配置
# ====================================

# CORS配置
ALLOWED_ORIGINS=*

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Helmet配置
CONTENT_SECURITY_POLICY=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# ====================================
# 匹配算法配置
# ====================================

MATCH_RECOMMEND_LIMIT=20
MATCH_LEVEL_WEIGHT=40
MATCH_TYPE_WEIGHT=35
MATCH_LOCATION_WEIGHT=15
MATCH_AGE_WEIGHT=10

# ====================================
# 无障碍配置
# ====================================
ACCESSIBILITY_FONT_SIZE=16
ACCESSIBILITY_HIGH_CONTRAST=false

# ====================================
# 敏感词过滤
# ====================================
ENABLE_SENSITIVE_WORD_FILTER=true
SENSITIVE_WORDS_PATH=./config/sensitive-words.txt

# ====================================
# 第三方服务配置（可选）
# ====================================

# 短信服务
SMS_PROVIDER=
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=

# 邮件服务
EMAIL_PROVIDER=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# 支付服务
PAYMENT_PROVIDER=
PAYMENT_APP_ID=
PAYMENT_PRIVATE_KEY=
PAYMENT_PUBLIC_KEY=

# ====================================
# 日志配置
# ====================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=10

# ====================================
# 监控配置（可选）
# ====================================
ENABLE_MONITORING=false
MONITORING_ENDPOINT=
SENTRY_DSN=
DATADOG_API_KEY=

# ====================================
# 缓存配置
# ====================================
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# ====================================
# 队列配置
# ====================================
ENABLE_QUEUE=true
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=1000

# ====================================
# 性能优化配置
# ====================================
ENABLE_COMPRESSION=true
ENABLE_RATE_LIMITING=true
ENABLE_HELMET=true
ENABLE_CORS=true

# ====================================
# WebSocket配置
# ====================================
SOCKET_IO_ENABLED=true
SOCKET_IO_PING_TIMEOUT=5000
SOCKET_IO_PING_INTERVAL=25000

# ====================================
# 文件清理配置
# ====================================
ENABLE_AUTO_CLEANUP=false
CLEANUP_INTERVAL_DAYS=30
CLEANUP_TEMP_FILES=true

# ====================================
# 备份配置
# ====================================
ENABLE_AUTO_BACKUP=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=./backups

# ====================================
# 通知配置
# ====================================
ENABLE_NOTIFICATIONS=true
NOTIFICATION_CHANNELS=email,sms,push
EMAIL_NOTIFICATIONS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=false
PUSH_NOTIFICATIONS_ENABLED=false

# ====================================
# 地理位置配置
# ====================================
ENABLE_GEOLOCATION=false
GEOLOCATION_API_KEY=
GEOLOCATION_PROVIDER=

# ====================================
# 内容审核配置
# ====================================
ENABLE_CONTENT_MODERATION=false
CONTENT_MODERATION_PROVIDER=
CONTENT_MODERATION_API_KEY=
CONTENT_MODERATION_THRESHOLD=0.8

# ====================================
# 调试配置（开发环境）
# ====================================
DEBUG=false
VERBOSE_LOGGING=false
ENABLE_PROFILING=false
ENABLE_STACK_TRACES=false
