# ====================================
# 通用数据库环境变量示例
# 支持所有厂商和所有类型的数据库
# ====================================

# 主数据库类型和连接字符串
# 根据需要选择其中一种

# 1. MongoDB（默认）
# MONGO_DB=fuyuan
# MONGO_USERNAME=admin
# MONGO_PASSWORD=changeme
# DATABASE_URI=mongodb://admin:changeme@mongodb:27017/fuyuan?authSource=admin

# 2. MySQL
# MYSQL_ROOT_PASSWORD=changeme
# MYSQL_DB=fuyuan
# MYSQL_USER=fuyuan
# MYSQL_PASSWORD=changeme
# DATABASE_URI=mysql://fuyuan:changeme@mysql:3306/fuyuan

# 3. PostgreSQL
# POSTGRES_DB=fuyuan
# POSTGRES_USER=fuyuan
# POSTGRES_PASSWORD=changeme
# DATABASE_URI=postgresql://fuyuan:changeme@postgres:5432/fuyuan

# 4. MariaDB
# MARIADB_ROOT_PASSWORD=changeme
# MARIADB_DB=fuyuan
# MARIADB_USER=fuyuan
# MARIADB_PASSWORD=changeme
# DATABASE_URI=mariadb://fuyuan:changeme@mariadb:3306/fuyuan

# 辅助数据库（可选）
DATABASE_AUX1_URI=
DATABASE_AUX2_URI=

# ====================================
# 云厂商数据库示例
# ====================================

# 阿里云RDS MySQL
# DATABASE_URI=mysql://username:password@rm-bp123456.mysql.rds.aliyuncs.com:3306/fuyuan

# 腾讯云CDB MySQL
# DATABASE_URI=mysql://username:password@cdb-123456.gz.tencentcdb.com:3306/fuyuan

# 华为云RDS MySQL
# DATABASE_URI=mysql://username:password@rds-123456.mysql.rds.myhuaweicloud.com:3306/fuyuan

# AWS RDS MySQL
# DATABASE_URI=mysql://username:password@db-instance.123456.us-east-1.rds.amazonaws.com:3306/fuyuan

# AWS RDS PostgreSQL
# DATABASE_URI=postgresql://username:password@db-instance.123456.us-east-1.rds.amazonaws.com:5432/fuyuan

# AWS DocumentDB (MongoDB兼容)
# DATABASE_URI=mongodb://username:password@docdb-123456-cluster.cluster-abc123.us-east-1.docdb.amazonaws.com:27017/fuyuan?ssl=true&replicaSet=rs0&readPreference=secondaryPreferred

# Google Cloud SQL MySQL
# DATABASE_URI=mysql://username:password@10.0.0.1:3306/fuyuan

# Azure SQL Database
# DATABASE_URI=sqlserver://username:password@server-name.database.windows.net:1433/fuyuan

# MongoDB Atlas
# DATABASE_URI=mongodb+srv://username:password@cluster0.abcde.mongodb.net/fuyuan?retryWrites=true&w=majority

# ====================================
# Redis配置
# ====================================
REDIS_PASSWORD=changeme

# 云厂商Redis示例
# 阿里云Redis: redis://:password@r-bp123456.redis.rds.aliyuncs.com:6379
# 腾讯云Redis: redis://:password@redis-123456.redis.tencentcloudapi.com:6379
# AWS ElastiCache: redis://:password@cluster-name.abc123.use1.cache.amazonaws.com:6379

# ====================================
# 连接池配置
# ====================================
DB_POOL_SIZE=20
DB_MIN_POOL_SIZE=5
DB_TIMEOUT=5000
DB_SOCKET_TIMEOUT=60000
DB_IDLE_TIMEOUT=30000

# ====================================
# 端口配置
# ====================================
BACKEND_PORT=3000
FRONTEND_PORT=80
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ====================================
# 其他配置
# ====================================
NODE_ENV=production

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

MAX_FILE_SIZE=10485760
ENABLE_SENSITIVE_WORD_FILTER=true

# RabbitMQ
RABBITMQ_URL=amqp://admin:changeme@rabbitmq:5672

# 管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# CORS
ALLOWED_ORIGINS=https://your-domain.com
